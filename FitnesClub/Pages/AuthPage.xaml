<Page x:Class="FitnesClub.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FitnesClub.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthPage"
      Background="#F0F0F0">
    

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>

        </Grid.RowDefinitions>

        <Border  Background="BlanchedAlmond" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="6">
            <TextBlock Text="Авторизация" HorizontalAlignment="Center"  FontSize="20" FontWeight="Black" VerticalAlignment="Center"  />

        </Border>
        <TextBlock Text="Логин" Grid.Column="2" Grid.Row="2" HorizontalAlignment="Center" FontSize="16" FontWeight="Black"/>
        <TextBlock Text="Пароль" Grid.Column="2" Grid.Row="3" HorizontalAlignment="Center" FontSize="16" FontWeight="Black" />
        <TextBox x:Name="tbLog" Grid.Column="3" Grid.Row="2"  Background="AliceBlue"/>
        <PasswordBox x:Name="tbPass" Grid.Column="3" Grid.Row="3" Background="AliceBlue"/>
        <Button x:Name="RegisterButton" Content="Регистрация" Click="RegisterButton_Click"  Grid.Column="2" Grid.ColumnSpan="2" Grid.Row="5" FontWeight="Black" Background="Azure"/>
        <Button x:Name="LoginButton" Content="Вход" Click="LoginButton_Click" Grid.Column="2" Grid.ColumnSpan="2" Grid.Row="4" FontWeight="Black" Background="BlanchedAlmond"/>

    </Grid>
</Page>