<Page x:Class="FitnesClub.Pages.RegPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FitnesClub.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="900"
      Title="RegPage"
      Background="#F0F0F0">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Border Background="BlanchedAlmond" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="9" CornerRadius="0">
            <TextBlock Text="Регистрация сотрудника" HorizontalAlignment="Center" FontSize="20" FontWeight="Black" VerticalAlignment="Center"/>
        </Border>

        <TextBlock Text="Имя:" Grid.Column="1" Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Margin="0,0,10,0"/>
        <TextBox x:Name="TBName" Grid.Column="2" Grid.ColumnSpan="3" Grid.Row="2" 
                 Height="35" VerticalAlignment="Center" Background="AliceBlue" Padding="8"/>

        <TextBlock Text="Фамилия:" Grid.Column="1" Grid.Row="3" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Margin="0,0,10,0"/>
        <TextBox x:Name="TBFam" Grid.Column="2" Grid.ColumnSpan="3" Grid.Row="3" 
                 Height="35" VerticalAlignment="Center" Background="AliceBlue" Padding="8"/>

        <TextBlock Text="Отчество:" Grid.Column="1" Grid.Row="4" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Margin="0,0,10,0"/>
        <TextBox x:Name="TBMid" Grid.Column="2" Grid.ColumnSpan="3" Grid.Row="4" 
                 Height="35" VerticalAlignment="Center" Background="AliceBlue" Padding="8"/>

        <TextBlock Text="Телефон:" Grid.Column="1" Grid.Row="5" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Margin="0,0,10,0"/>
        <TextBox x:Name="TBPhone" Grid.Column="2" Grid.ColumnSpan="3" Grid.Row="5" 
                 Height="35" VerticalAlignment="Center" Background="AliceBlue" Padding="8"/>

        <TextBlock Text="Email:" Grid.Column="1" Grid.Row="6" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Margin="0,0,10,0"/>
        <TextBox x:Name="TBEmail" Grid.Column="2" Grid.ColumnSpan="3" Grid.Row="6" 
                 Height="35" VerticalAlignment="Center" Background="AliceBlue" Padding="8"/>

        <TextBlock Text="Должность:" Grid.Column="5" Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Margin="0,0,10,0"/>
        <ComboBox x:Name="CBPosition" Grid.Column="6" Grid.ColumnSpan="2" Grid.Row="2" 
                  Height="35" VerticalAlignment="Center" Background="AliceBlue" Padding="5">
            <ComboBoxItem Content="Administrator"/>
            <ComboBoxItem Content="Manager"/>
            <ComboBoxItem Content="Trainer"/>
            <ComboBoxItem Content="Cleaner"/>
        </ComboBox>

        <TextBlock Text="Зарплата:" Grid.Column="5" Grid.Row="4" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Margin="0,0,10,0"/>
        <TextBox x:Name="TBSalary" Grid.Column="6" Grid.ColumnSpan="2" Grid.Row="4" 
                 Height="35" VerticalAlignment="Center" Background="AliceBlue" Padding="8"/>

        <TextBlock Text="Дата рождения:" Grid.Column="5" Grid.Row="5" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Margin="0,0,10,0"/>
        <DatePicker x:Name="DPBirthDate" Grid.Column="6" Grid.ColumnSpan="2" Grid.Row="5" 
                    Height="35" VerticalAlignment="Center" Background="AliceBlue"/>

        <TextBlock Text="Пароль:" Grid.Column="1" Grid.Row="7" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="14" FontWeight="SemiBold" Margin="42,8,0,0" RenderTransformOrigin="-7.068,0.339"/>
        <PasswordBox x:Name="TBPassword" Grid.Column="2" Grid.ColumnSpan="2" Grid.Row="7" 
                     Height="34" VerticalAlignment="Center" Background="AliceBlue" Padding="5"/>

        <CheckBox x:Name="CBActive" Grid.Column="2" Grid.ColumnSpan="3" Grid.Row="8" 
                  Content="Активный сотрудник" IsChecked="True" 
                  VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14"/>

        <TextBlock Text="Паспорт:" Grid.Column="5" Grid.Row="8" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Margin="0,0,10,0"/>
        <TextBox x:Name="TBPassport" Grid.Column="6" Grid.ColumnSpan="2" Grid.Row="8" 
                 Height="35" VerticalAlignment="Center" Background="AliceBlue" Padding="8"/>

        <Button x:Name="btnSave" Content="Сохранить" Click="btnSave_Click" 
                Grid.Column="3" Grid.ColumnSpan="2" Grid.Row="9" 
                Height="40" Width="150" FontWeight="Black" Background="BlanchedAlmond"/>

        <Button x:Name="btnBack" Content="Назад" Click="btnBack_Click" 
                Grid.Column="5" Grid.ColumnSpan="2" Grid.Row="9" 
                Height="40" Width="150" FontWeight="Black" Background="Azure"/>

    </Grid>
</Page>